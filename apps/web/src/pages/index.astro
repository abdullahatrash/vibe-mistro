---
// The marketing page (#271, ADR-0018). Release links use GitHub's permanent
// latest-download redirects, so a new desktop release never requires a redeploy.
import '@fontsource-variable/geist'
import '@fontsource-variable/geist-mono'

const DOWNLOAD_URL =
  'https://github.com/abdullahatrash/vibe-mistro/releases/latest/download/Vibe-Mistro-arm64.dmg'
const DOWNLOAD_URL_LINUX =
  'https://github.com/abdullahatrash/vibe-mistro/releases/latest/download/Vibe-Mistro.AppImage'
const DOWNLOAD_URL_LINUX_DEB =
  'https://github.com/abdullahatrash/vibe-mistro/releases/latest/download/Vibe-Mistro.deb'
const REPO_URL = 'https://github.com/abdullahatrash/vibe-mistro'
const VIBE_CLI_URL = 'https://docs.mistral.ai/vibe/code/cli/install-setup'
const YEAR = new Date().getFullYear()
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#fbfaf8" />
    <title>Vibe Mistro — a desktop home for Mistral Vibe</title>
    <meta
      name="description"
      content="Run Mistral Vibe coding agents across local Workspaces from one calm desktop app. Keep durable Threads, approvals, files, git, and a terminal close at hand."
    />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content="Vibe Mistro" />
    <meta
      property="og:description"
      content="A light, open-source desktop home for your Mistral Vibe coding agents."
    />
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>

    <header class="site-header">
      <div class="container nav-shell">
        <a class="brand" href="/" aria-label="Vibe Mistro home">
          <svg class="brand-mark" viewBox="0 0 64 64" aria-hidden="true">
            <defs>
              <linearGradient id="vm-flame" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0" stop-color="#f6c445"></stop>
                <stop offset=".55" stop-color="#ef8a3c"></stop>
                <stop offset="1" stop-color="#e2452a"></stop>
              </linearGradient>
            </defs>
            <rect width="64" height="64" rx="15" fill="url(#vm-flame)"></rect>
            <path
              d="M19 19 32 46 45 19"
              fill="none"
              stroke="#241a12"
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="8.5"></path>
          </svg>
          <span>Vibe Mistro</span>
          <span class="beta-chip">Beta</span>
        </a>

        <nav aria-label="Primary navigation">
          <a href="#workflow">Workflow</a>
          <a href="#under-the-hood">How it works</a>
          <a href={REPO_URL} target="_blank" rel="noreferrer">GitHub</a>
        </nav>

        <a class="header-download" href={DOWNLOAD_URL}>
          Get the app
          <svg viewBox="0 0 20 20" aria-hidden="true">
            <path d="m6 14 8-8m-6 0h6v6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path>
          </svg>
        </a>
      </div>
    </header>

    <main id="main">
      <section class="hero">
        <div class="hero-grid" aria-hidden="true"></div>
        <div class="hero-glow hero-glow-one" aria-hidden="true"></div>
        <div class="hero-glow hero-glow-two" aria-hidden="true"></div>

        <div class="container hero-copy">
          <p class="eyebrow hero-eyebrow">
            <span class="live-dot"></span>
            Open source · macOS &amp; Linux
          </p>
          <h1>
            Mistral Vibe,<br />
            <span>with room to think.</span>
          </h1>
          <p class="lede">
            Keep every local Workspace, durable Thread, approval, diff, and shell in one calm
            desktop window. Vibe writes the code. Mistro keeps the work legible.
          </p>
          <div class="hero-actions">
            <a class="button button-primary" href={DOWNLOAD_URL}>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.05 20.28c-.98.95-2.05.86-3.08.38-1.09-.5-2.08-.53-3.2 0-1.44.62-2.2.44-3.06-.38C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08ZM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25Z"></path>
              </svg>
              Download for macOS
            </a>
            <a class="button button-ghost" href={REPO_URL} target="_blank" rel="noreferrer">
              View source
              <svg viewBox="0 0 20 20" aria-hidden="true">
                <path d="m6 14 8-8m-6 0h6v6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path>
              </svg>
            </a>
          </div>
          <p class="hero-note">
            Apple Silicon · Linux x64 · Free and MIT licensed · Requires the
            <a href={VIBE_CLI_URL} target="_blank" rel="noreferrer">Mistral Vibe CLI</a>
          </p>
        </div>

        <div class="container app-stage">
          <div class="stage-label stage-label-workspace" aria-hidden="true">
            <span class="status-dot status-working"></span>
            Workspace agent is warm
          </div>
          <div class="stage-label stage-label-thread" aria-hidden="true">
            <span class="thread-glyph">↳</span>
            Threads resume here
          </div>
          <div class="stage-card">
            <div class="stage-toolbar" aria-hidden="true">
              <div class="traffic-lights"><span></span><span></span><span></span></div>
              <span class="stage-title">Vibe Mistro</span>
              <span class="stage-state"><i></i> Agent connected</span>
            </div>
            <div class="screenshot-shell">
              <img
                src="/app-screenshot.jpg"
                width="1800"
                height="1126"
                alt="Vibe Mistro showing Workspace Threads, a live Mistral Vibe conversation, and the Files panel"
                loading="eager"
                decoding="async"
                fetchpriority="high"
              />
            </div>
          </div>
          <div class="stage-caption">
            <span><b>01</b> Workspaces stay warm</span>
            <span><b>02</b> Threads stay durable</span>
            <span><b>03</b> Your code stays local</span>
          </div>
        </div>
      </section>

      <section class="signal-strip" aria-label="Product principles">
        <div class="signal-track">
          <span>One Vibe process per open Workspace</span>
          <i></i>
          <span>Many durable Threads</span>
          <i></i>
          <span>Raw ACP events, faithfully rendered</span>
          <i></i>
          <span>No credentials stored</span>
          <i></i>
          <span>Local files stay local</span>
        </div>
      </section>

      <section class="section workflow" id="workflow">
        <div class="container">
          <div class="section-intro split-intro">
            <div>
              <p class="eyebrow">Parallel by default</p>
              <h2>Know what every agent is doing—without babysitting terminals.</h2>
            </div>
            <p>
              Open a Workspace when you need it. Keep several Threads moving inside it. The sidebar
              tells you what is streaming, waiting for approval, or ready for your next prompt.
            </p>
          </div>

          <div class="workspace-demo">
            <div class="demo-sidebar">
              <div class="demo-sidebar-head">
                <span>Workspaces</span>
                <span class="mini-button">＋</span>
              </div>

              <div class="demo-workspace">
                <div class="workspace-row">
                  <span class="chevron">⌄</span>
                  <span class="folder-icon"></span>
                  <strong>checkout-redesign</strong>
                  <span class="status-dot status-working"></span>
                </div>
                <div class="thread-row is-active">
                  <span class="status-dot status-streaming"></span>
                  <span>Fix mobile payment flow</span>
                  <small>now</small>
                </div>
                <div class="thread-row">
                  <span class="status-dot status-idle"></span>
                  <span>Audit failed webhooks</span>
                  <small>12m</small>
                </div>
              </div>

              <div class="demo-workspace">
                <div class="workspace-row">
                  <span class="chevron">⌄</span>
                  <span class="folder-icon"></span>
                  <strong>docs-site</strong>
                  <span class="status-dot status-attention"></span>
                </div>
                <div class="thread-row needs-attention">
                  <span class="status-dot status-attention"></span>
                  <span>Refresh API examples</span>
                  <small>!</small>
                </div>
                <div class="thread-row">
                  <span class="status-dot status-idle"></span>
                  <span>Improve first-run guide</span>
                  <small>1h</small>
                </div>
              </div>

              <div class="demo-workspace is-collapsed">
                <div class="workspace-row">
                  <span class="chevron">›</span>
                  <span class="folder-icon"></span>
                  <strong>design-system</strong>
                  <span class="status-dot status-idle"></span>
                </div>
              </div>
            </div>

            <div class="demo-main">
              <div class="demo-main-head">
                <div>
                  <span class="status-dot status-streaming"></span>
                  <strong>Fix mobile payment flow</strong>
                </div>
                <span class="connected-chip">connected</span>
              </div>

              <div class="activity-feed">
                <div class="activity-line">
                  <span class="activity-icon">⌁</span>
                  <div>
                    <strong>Read</strong>
                    <code>src/payments/checkout.ts</code>
                  </div>
                  <span class="activity-ok">✓</span>
                </div>
                <div class="activity-line">
                  <span class="activity-icon activity-icon-warm">✦</span>
                  <div>
                    <strong>Reasoning</strong>
                    <p>The retry branch is losing the original payment intent…</p>
                  </div>
                  <span class="working-dots"><i></i><i></i><i></i></span>
                </div>
                <div class="activity-line is-muted">
                  <span class="activity-icon">⌘</span>
                  <div>
                    <strong>Run</strong>
                    <code>bun test checkout</code>
                  </div>
                  <span class="activity-ok">✓</span>
                </div>
              </div>

              <div class="agent-answer">
                <span class="answer-kicker">Vibe</span>
                <p>
                  I found the race: the retry path creates a second intent before the first request
                  resolves. I’m moving intent creation behind the idempotency guard and adding a
                  regression test.
                </p>
                <div class="change-summary">
                  <span>2 files changed</span>
                  <strong>+28</strong>
                  <em>−9</em>
                </div>
              </div>

              <div class="composer-demo">
                <span>Ask for follow-up changes</span>
                <div class="composer-controls">
                  <span>＋</span>
                  <span>◇ Default</span>
                  <span>◎ mistral-medium</span>
                  <b>↑</b>
                </div>
              </div>
            </div>

            <aside class="activity-legend">
              <p class="legend-label">Live status</p>
              <div>
                <span class="legend-mark streaming-mark"></span>
                <p><strong>Streaming</strong><small>Vibe is working now</small></p>
              </div>
              <div>
                <span class="legend-mark attention-mark">!</span>
                <p><strong>Needs attention</strong><small>A decision is waiting</small></p>
              </div>
              <div>
                <span class="legend-mark ready-mark">✓</span>
                <p><strong>Ready</strong><small>Pick up where you left off</small></p>
              </div>
              <div class="legend-rule"></div>
              <p class="legend-note">The app stays quiet until a Thread actually needs you.</p>
            </aside>
          </div>
        </div>
      </section>

      <section class="section under-the-hood" id="under-the-hood">
        <div class="container">
          <div class="section-intro compact-intro">
            <p class="eyebrow">Thin on purpose</p>
            <h2>Vibe keeps the intelligence.<br />Mistro gives it a proper room.</h2>
            <p>
              No embedded model. No second agent loop. Vibe Mistro speaks the Agent Client Protocol,
              supervises the process, and turns its live work into a desktop interface.
            </p>
          </div>

          <div class="protocol-flow" aria-label="How Vibe Mistro connects you to Mistral Vibe and your Workspace">
            <div class="flow-node human-node">
              <span class="node-number">01</span>
              <span class="node-icon">You</span>
              <strong>Prompt &amp; decide</strong>
              <small>One clear desktop surface</small>
            </div>
            <div class="flow-arrow" aria-hidden="true"><span>prompt</span>→</div>
            <div class="flow-node mistro-node">
              <span class="node-number">02</span>
              <svg class="flow-logo" viewBox="0 0 64 64" aria-hidden="true">
                <rect width="64" height="64" rx="15" fill="#ef8a3c"></rect>
                <path d="M19 19 32 46 45 19" fill="none" stroke="#241a12" stroke-linecap="round" stroke-linejoin="round" stroke-width="8.5"></path>
              </svg>
              <strong>Vibe Mistro</strong>
              <small>Orchestrate &amp; render</small>
            </div>
            <div class="flow-arrow" aria-hidden="true"><span>ACP</span>→</div>
            <div class="flow-node vibe-node">
              <span class="node-number">03</span>
              <span class="vibe-pixel" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
              <strong>Mistral Vibe</strong>
              <small>Reason, choose tools, code</small>
            </div>
            <div class="flow-arrow" aria-hidden="true"><span>tools</span>→</div>
            <div class="flow-node workspace-node">
              <span class="node-number">04</span>
              <span class="code-braces">&#123; &#125;</span>
              <strong>Your Workspace</strong>
              <small>Files, git, and shell</small>
            </div>
          </div>

          <div class="principle-row">
            <span><b>Unconfined reads</b> for CLI parity</span>
            <span><b>Workspace-confined writes</b> for safety</span>
            <span><b>Credentials stay with Vibe</b>, never with Mistro</span>
          </div>
        </div>
      </section>

      <section class="section approvals">
        <div class="container approval-grid">
          <div class="approval-copy">
            <p class="eyebrow">Your call, at the right moment</p>
            <h2>Stay in the loop without living in the loop.</h2>
            <p>
              Permission requests arrive inside the Thread that caused them. Approve one action,
              reject it, or choose a different approval posture for the work ahead.
            </p>
            <ul>
              <li><span>01</span>Plan before touching code</li>
              <li><span>02</span>Accept edits while guarding commands</li>
              <li><span>03</span>Give trusted Threads more autonomy</li>
            </ul>
          </div>

          <div class="permission-scene">
            <div class="permission-backplate" aria-hidden="true">
              <span>MODE</span>
              <b>Default</b>
              <span>MODEL</span>
              <b>mistral-medium</b>
              <span>EFFORT</span>
              <b>Max</b>
            </div>
            <div class="permission-card">
              <div class="permission-head">
                <span class="shield-icon">◇</span>
                <div>
                  <strong>Permission requested</strong>
                  <small>Vibe is paused until you decide</small>
                </div>
                <span class="permission-time">now</span>
              </div>
              <div class="permission-body">
                <p>Run a command in this Workspace?</p>
                <code>bun run test src/main/agent-pool.test.ts</code>
                <span class="path-label">checkout-redesign · local shell</span>
              </div>
              <div class="permission-actions">
                <span class="permission-reject">Reject</span>
                <span class="permission-allow">Allow once</span>
              </div>
            </div>
            <div class="mode-switcher" aria-label="Available approval modes">
              <span class="is-selected">Default</span>
              <span>Plan</span>
              <span>Accept edits</span>
              <span>Auto-approve</span>
            </div>
          </div>
        </div>
      </section>

      <section class="section side-work">
        <div class="container">
          <div class="section-intro split-intro side-work-intro">
            <div>
              <p class="eyebrow">Everything beside the conversation</p>
              <h2>The side work stays beside the work.</h2>
            </div>
            <p>
              Inspect files, review a diff, stage a change, or open a real shell without losing the
              Thread that explains why you are doing it.
            </p>
          </div>

          <div class="side-work-stage">
            <div class="surface-files">
              <div class="surface-head"><strong>Files</strong><span>146 files</span><i>⌕</i></div>
              <div class="file-search">Search Workspace…</div>
              <div class="file-tree">
                <span>⌄ <b>src</b></span>
                <span class="depth-one">⌄ <b>main</b></span>
                <span class="depth-two is-file">◇ agent-pool.ts</span>
                <span class="depth-two is-file is-active">◇ thread-binding.ts</span>
                <span class="depth-two is-file">◇ persistence.ts</span>
                <span class="depth-one">› <b>renderer</b></span>
                <span class="is-file">◇ package.json</span>
              </div>
            </div>

            <div class="surface-git">
              <div class="surface-head"><strong>Changes</strong><span>3 files</span><i>↻</i></div>
              <div class="branch-row"><span>⌘</span><b>feat/thread-resume</b><small>main</small></div>
              <div class="diff-file"><span>M</span><code>thread-binding.ts</code><b>+18</b><em>−4</em></div>
              <div class="diff-file"><span>M</span><code>index.ts</code><b>+7</b><em>−2</em></div>
              <div class="diff-file"><span>A</span><code>thread-binding.test.ts</code><b>+41</b><em>−0</em></div>
              <div class="commit-box">Resume a Thread after agent eviction</div>
              <div class="commit-button">Commit 3 files <span>⌘↵</span></div>
            </div>

            <div class="surface-terminal">
              <div class="terminal-head">
                <span><i></i><i></i><i></i></span>
                <strong>Workspace shell</strong>
                <small>zsh</small>
              </div>
              <div class="terminal-body">
                <p><b>~/checkout-redesign</b> <span>git:(feat/thread-resume)</span></p>
                <p><i>$</i> bun run test thread-binding</p>
                <p class="terminal-muted">✓ 8 tests passed in 231ms</p>
                <p><i>$</i> <em class="terminal-cursor"></em></p>
              </div>
            </div>
          </div>

          <div class="surface-tabs" aria-label="Side surfaces shown above">
            <span><b>01</b> Files</span>
            <span><b>02</b> Git</span>
            <span><b>03</b> Terminal</span>
            <span><b>04</b> Skills</span>
          </div>
        </div>
      </section>

      <section class="section open-source">
        <div class="container">
          <div class="open-panel">
            <div class="open-grid" aria-hidden="true"></div>
            <div class="open-copy">
              <p class="eyebrow">Open from the protocol up</p>
              <h2>Read it. Fork it.<br />Make it yours.</h2>
              <p>
                Vibe Mistro is an MIT-licensed Electron app built in the open. The architecture is
                documented, the protocol boundary is explicit, and your local workflow stays yours.
              </p>
              <div class="open-actions">
                <a class="button button-dark" href={REPO_URL} target="_blank" rel="noreferrer">
                  Browse the source
                  <svg viewBox="0 0 20 20" aria-hidden="true"><path d="m6 14 8-8m-6 0h6v6" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path></svg>
                </a>
                <span>MIT licensed</span>
              </div>
            </div>

            <div class="open-terminal">
              <div class="open-terminal-head">
                <span></span><span></span><span></span>
                <small>~/code</small>
              </div>
              <div class="open-terminal-body">
                <p><i>$</i> git clone {REPO_URL}.git</p>
                <p class="terminal-comment">Cloning into 'vibe-mistro'… done.</p>
                <p><i>$</i> cd vibe-mistro &amp;&amp; bun install</p>
                <p class="terminal-comment">2361 packages installed</p>
                <p><i>$</i> bun run dev</p>
                <p class="terminal-success">✓ Vibe Mistro is ready</p>
                <p><i>$</i> <em class="terminal-cursor"></em></p>
              </div>
            </div>
          </div>
        </div>
      </section>

      <section class="final-cta">
        <div class="final-grid" aria-hidden="true"></div>
        <div class="container final-cta-inner">
          <p class="eyebrow">Your next Thread starts here</p>
          <h2>Give Vibe a window.</h2>
          <p>Free, open source, and built for the Mistral Vibe subscription you already use.</p>
          <div class="hero-actions">
            <a class="button button-primary" href={DOWNLOAD_URL}>
              <svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.05 20.28c-.98.95-2.05.86-3.08.38-1.09-.5-2.08-.53-3.2 0-1.44.62-2.2.44-3.06-.38C2.79 15.25 3.51 7.59 9.05 7.31c1.35.07 2.29.74 3.08.8 1.18-.24 2.31-.93 3.57-.84 1.51.12 2.65.72 3.4 1.8-3.12 1.87-2.38 5.98.48 7.13-.57 1.5-1.31 2.99-2.53 4.08ZM12.03 7.25c-.15-2.23 1.66-4.07 3.74-4.25.29 2.58-2.34 4.5-3.74 4.25Z"></path>
              </svg>
              Download for macOS
            </a>
            <a class="button button-ghost" href={DOWNLOAD_URL_LINUX}>
              Download for Linux
              <svg viewBox="0 0 20 20" aria-hidden="true"><path d="M10 3v10m-4-4 4 4 4-4M4 16h12" fill="none" stroke="currentColor" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.6"></path></svg>
            </a>
          </div>
          <p class="final-note">Using Debian or Ubuntu? <a href={DOWNLOAD_URL_LINUX_DEB}>Download the .deb package.</a></p>
        </div>
      </section>
    </main>

    <footer>
      <div class="container footer-inner">
        <a class="brand footer-brand" href="/" aria-label="Vibe Mistro home">
          <svg class="brand-mark" viewBox="0 0 64 64" aria-hidden="true">
            <rect width="64" height="64" rx="15" fill="#ef8a3c"></rect>
            <path d="M19 19 32 46 45 19" fill="none" stroke="#241a12" stroke-linecap="round" stroke-linejoin="round" stroke-width="8.5"></path>
          </svg>
          <span>Vibe Mistro</span>
        </a>
        <p>© {YEAR} · MIT licensed · An open-source companion for Mistral Vibe.</p>
        <div class="footer-links">
          <a href={REPO_URL} target="_blank" rel="noreferrer">GitHub</a>
          <a href={VIBE_CLI_URL} target="_blank" rel="noreferrer">Vibe CLI</a>
          <a href={DOWNLOAD_URL}>Download</a>
        </div>
      </div>
      <div class="container disclaimer">Not affiliated with Mistral AI.</div>
    </footer>

    <style is:global>
      :root {
        --bg: #fbfaf8;
        --bg-deep: #f5f3ef;
        --surface: #fdfcfb;
        --panel: #ffffff;
        --border: #ecdfd3;
        --border-strong: #ddcfc1;
        --text: #1c1c1c;
        --text-body: #33302c;
        --muted: #6b645d;
        --faint: #a89f95;
        --accent: #df6f38;
        --accent-strong: #c9542c;
        --accent-soft: #f8e0cf;
        --accent-pale: #fff1e7;
        --gold: #f6c445;
        --green: #3a9a55;
        --terminal: #1c1b1a;
        --sans: 'Geist Variable', -apple-system, BlinkMacSystemFont, 'SF Pro Text', sans-serif;
        --mono: 'Geist Mono Variable', ui-monospace, 'SF Mono', Menlo, monospace;
        --shadow-small: 0 1px 2px rgba(54, 36, 22, 0.06), 0 8px 24px rgba(68, 39, 18, 0.05);
        --shadow-large: 0 34px 90px -42px rgba(74, 43, 24, 0.45), 0 8px 24px rgba(84, 49, 29, 0.08);
      }

      * {
        box-sizing: border-box;
        margin: 0;
      }

      html {
        scroll-behavior: smooth;
        background: var(--bg);
        color: var(--text);
        font-family: var(--sans);
        -webkit-font-smoothing: antialiased;
      }

      body {
        min-width: 320px;
        overflow-x: hidden;
        background: var(--bg);
      }

      a {
        color: inherit;
      }

      button,
      a {
        -webkit-tap-highlight-color: transparent;
      }

      a:focus-visible {
        outline: 3px solid rgba(223, 111, 56, 0.3);
        outline-offset: 4px;
      }

      .container {
        width: min(100% - 48px, 1180px);
        margin-inline: auto;
      }

      .skip-link {
        position: fixed;
        top: 10px;
        left: 10px;
        z-index: 100;
        transform: translateY(-150%);
        border-radius: 8px;
        background: var(--text);
        color: white;
        padding: 10px 14px;
        text-decoration: none;
      }

      .skip-link:focus {
        transform: none;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 50;
        border-bottom: 1px solid rgba(221, 207, 193, 0.72);
        background: rgba(251, 250, 248, 0.84);
        backdrop-filter: blur(18px) saturate(1.3);
      }

      .nav-shell {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        min-height: 68px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        justify-self: start;
        gap: 10px;
        width: fit-content;
        color: var(--text);
        font-size: 16px;
        font-weight: 660;
        letter-spacing: -0.02em;
        text-decoration: none;
      }

      .brand-mark {
        width: 28px;
        height: 28px;
        filter: drop-shadow(0 4px 8px rgba(198, 82, 31, 0.16));
      }

      .beta-chip {
        border: 1px solid var(--border);
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        color: var(--accent-strong);
        font-size: 10px;
        font-weight: 650;
        letter-spacing: 0.08em;
        line-height: 1;
        padding: 5px 7px 4px;
        text-transform: uppercase;
      }

      nav {
        display: flex;
        align-items: center;
        gap: 30px;
      }

      nav a,
      .footer-links a {
        color: var(--muted);
        font-size: 14px;
        text-decoration: none;
        transition: color 150ms ease;
      }

      nav a:hover,
      .footer-links a:hover {
        color: var(--accent-strong);
      }

      .header-download {
        display: inline-flex;
        align-items: center;
        justify-self: end;
        gap: 8px;
        border: 1px solid var(--text);
        border-radius: 9px;
        background: var(--text);
        color: white;
        font-size: 13px;
        font-weight: 620;
        padding: 9px 13px;
        text-decoration: none;
        transition: transform 150ms ease, background 150ms ease;
      }

      .header-download:hover {
        transform: translateY(-1px);
        background: #37322e;
      }

      .header-download svg,
      .button svg {
        width: 16px;
        height: 16px;
      }

      .hero {
        position: relative;
        overflow: hidden;
        padding: 108px 0 0;
        isolation: isolate;
      }

      .hero-grid,
      .final-grid,
      .open-grid {
        position: absolute;
        inset: 0;
        z-index: -2;
        background-image:
          linear-gradient(rgba(207, 106, 58, 0.07) 1px, transparent 1px),
          linear-gradient(90deg, rgba(207, 106, 58, 0.07) 1px, transparent 1px);
        background-size: 42px 42px;
        mask-image: linear-gradient(to bottom, black 0, rgba(0, 0, 0, 0.75) 36%, transparent 78%);
        -webkit-mask-image: linear-gradient(to bottom, black 0, rgba(0, 0, 0, 0.75) 36%, transparent 78%);
      }

      .hero-glow {
        position: absolute;
        z-index: -1;
        width: 420px;
        height: 420px;
        border-radius: 50%;
        filter: blur(20px);
        opacity: 0.45;
      }

      .hero-glow-one {
        top: 0;
        left: -250px;
        background: radial-gradient(circle, rgba(246, 196, 69, 0.3), transparent 68%);
      }

      .hero-glow-two {
        top: 160px;
        right: -270px;
        background: radial-gradient(circle, rgba(226, 69, 42, 0.18), transparent 68%);
      }

      .hero-copy {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .eyebrow {
        color: var(--accent-strong);
        font-family: var(--mono);
        font-size: 12px;
        font-weight: 600;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .hero-eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 9px;
        opacity: 0;
        animation: enter 650ms 80ms ease forwards;
      }

      .live-dot,
      .status-dot {
        display: inline-block;
        flex: 0 0 auto;
        width: 7px;
        height: 7px;
        border-radius: 999px;
      }

      .live-dot {
        background: var(--green);
        box-shadow: 0 0 0 5px rgba(58, 154, 85, 0.1);
      }

      h1 {
        max-width: 990px;
        margin-top: 26px;
        font-size: clamp(64px, 8.2vw, 106px);
        font-weight: 610;
        letter-spacing: -0.065em;
        line-height: 0.92;
        text-wrap: balance;
        opacity: 0;
        transform: translateY(18px);
        animation: enter 720ms 150ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      h1 span {
        color: var(--accent-strong);
      }

      .lede {
        max-width: 720px;
        margin-top: 31px;
        color: var(--text-body);
        font-size: clamp(18px, 2vw, 22px);
        letter-spacing: -0.02em;
        line-height: 1.5;
        text-wrap: balance;
        opacity: 0;
        transform: translateY(14px);
        animation: enter 650ms 250ms ease forwards;
      }

      .hero-actions {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 11px;
        margin-top: 34px;
      }

      .hero-copy .hero-actions,
      .hero-note {
        opacity: 0;
        transform: translateY(12px);
        animation: enter 600ms 340ms ease forwards;
      }

      .button {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        min-height: 50px;
        border-radius: 11px;
        font-size: 15px;
        font-weight: 640;
        padding: 0 20px;
        text-decoration: none;
        transition: transform 150ms ease, box-shadow 150ms ease, background 150ms ease;
      }

      .button:hover {
        transform: translateY(-2px);
      }

      .button-primary {
        border: 1px solid #cf6532;
        background: linear-gradient(160deg, #ee9b5b, #df6f38);
        color: #241a12;
        box-shadow: 0 12px 28px -12px rgba(200, 90, 30, 0.52), inset 0 1px rgba(255, 255, 255, 0.35);
      }

      .button-primary:hover {
        box-shadow: 0 16px 32px -12px rgba(200, 90, 30, 0.62), inset 0 1px rgba(255, 255, 255, 0.35);
      }

      .button-ghost {
        border: 1px solid var(--border-strong);
        background: rgba(253, 252, 251, 0.78);
        color: var(--text-body);
        box-shadow: var(--shadow-small);
      }

      .button-ghost:hover {
        background: white;
        box-shadow: 0 10px 24px -12px rgba(54, 36, 22, 0.3);
      }

      .hero-note,
      .final-note {
        margin-top: 16px;
        color: var(--muted);
        font-size: 13px;
        line-height: 1.5;
      }

      .hero-note a,
      .final-note a {
        color: var(--accent-strong);
        text-underline-offset: 3px;
      }

      .app-stage {
        position: relative;
        margin-top: 86px;
        opacity: 0;
        transform: translateY(26px) scale(0.99);
        animation: enter 850ms 420ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
      }

      .stage-card {
        position: relative;
        z-index: 2;
        border: 1px solid var(--border-strong);
        border-radius: 25px;
        background: #eee8e1;
        box-shadow: var(--shadow-large);
        padding: 7px;
      }

      .stage-toolbar {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        height: 43px;
        padding: 0 13px;
        color: var(--muted);
        font-size: 11px;
      }

      .traffic-lights,
      .open-terminal-head {
        display: flex;
        gap: 6px;
      }

      .traffic-lights span,
      .open-terminal-head > span {
        width: 9px;
        height: 9px;
        border-radius: 50%;
        background: #ec6a5e;
      }

      .traffic-lights span:nth-child(2),
      .open-terminal-head > span:nth-child(2) {
        background: #f4bf4f;
      }

      .traffic-lights span:nth-child(3),
      .open-terminal-head > span:nth-child(3) {
        background: #61c554;
      }

      .stage-title {
        font-weight: 600;
      }

      .stage-state {
        display: flex;
        align-items: center;
        justify-self: end;
        gap: 6px;
      }

      .stage-state i {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--green);
      }

      .screenshot-shell {
        overflow: hidden;
        border: 1px solid rgba(196, 179, 164, 0.85);
        border-radius: 17px;
        background: white;
      }

      .screenshot-shell img {
        display: block;
        width: 100%;
        height: auto;
      }

      .stage-label {
        position: absolute;
        z-index: 4;
        display: flex;
        align-items: center;
        gap: 8px;
        border: 1px solid var(--border-strong);
        border-radius: 999px;
        background: rgba(253, 252, 251, 0.94);
        box-shadow: 0 16px 34px -16px rgba(65, 39, 21, 0.3);
        color: var(--text-body);
        font-family: var(--mono);
        font-size: 11px;
        padding: 10px 13px;
        backdrop-filter: blur(10px);
      }

      .stage-label-workspace {
        top: 18%;
        left: -60px;
        transform: rotate(-4deg);
        animation: float-one 5s ease-in-out infinite;
      }

      .stage-label-thread {
        top: 47%;
        right: -54px;
        transform: rotate(3deg);
        animation: float-two 5.5s 600ms ease-in-out infinite;
      }

      .status-working,
      .status-streaming {
        background: var(--green);
        box-shadow: 0 0 0 3px rgba(58, 154, 85, 0.1);
      }

      .status-streaming {
        animation: status-pulse 1.8s ease-in-out infinite;
      }

      .thread-glyph {
        color: var(--accent-strong);
        font-size: 16px;
      }

      .stage-caption {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 20px;
        padding: 22px 10px 78px;
        color: var(--muted);
        font-family: var(--mono);
        font-size: 11px;
        text-transform: uppercase;
      }

      .stage-caption span {
        display: flex;
        align-items: center;
        gap: 9px;
      }

      .stage-caption span:nth-child(2) {
        justify-content: center;
      }

      .stage-caption span:last-child {
        justify-content: flex-end;
      }

      .stage-caption b {
        color: var(--accent-strong);
      }

      .signal-strip {
        overflow: hidden;
        border-block: 1px solid var(--border);
        background: var(--bg-deep);
      }

      .signal-track {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 26px;
        min-width: max-content;
        min-height: 65px;
        padding-inline: 24px;
        color: var(--muted);
        font-family: var(--mono);
        font-size: 11px;
        letter-spacing: 0.03em;
        text-transform: uppercase;
      }

      .signal-track i {
        width: 4px;
        height: 4px;
        border-radius: 50%;
        background: var(--accent);
      }

      .section {
        border-top: 1px solid var(--border);
        padding: 118px 0;
      }

      .section-intro h2,
      .approval-copy h2,
      .open-copy h2,
      .final-cta h2 {
        color: var(--text);
        font-size: clamp(44px, 5.2vw, 68px);
        font-weight: 570;
        letter-spacing: -0.055em;
        line-height: 0.98;
        text-wrap: balance;
      }

      .section-intro .eyebrow,
      .approval-copy .eyebrow,
      .open-copy .eyebrow,
      .final-cta .eyebrow {
        margin-bottom: 22px;
      }

      .split-intro {
        display: grid;
        grid-template-columns: minmax(0, 1.5fr) minmax(270px, 0.65fr);
        align-items: end;
        gap: clamp(50px, 9vw, 130px);
      }

      .split-intro > p,
      .compact-intro > p:last-child,
      .approval-copy > p,
      .open-copy > p,
      .final-cta-inner > p:not(.eyebrow):not(.final-note) {
        color: var(--muted);
        font-size: 17px;
        letter-spacing: -0.01em;
        line-height: 1.65;
      }

      .workflow {
        border-top: 0;
      }

      .workflow,
      .under-the-hood {
        scroll-margin-top: 86px;
      }

      .workspace-demo {
        display: grid;
        grid-template-columns: 245px minmax(0, 1fr) 205px;
        min-height: 610px;
        overflow: hidden;
        margin-top: 72px;
        border: 1px solid var(--border-strong);
        border-radius: 24px;
        background: var(--surface);
        box-shadow: var(--shadow-large);
      }

      .demo-sidebar {
        border-right: 1px solid var(--border);
        background: var(--bg-deep);
        padding: 19px 10px;
      }

      .demo-sidebar-head,
      .workspace-row,
      .thread-row,
      .demo-main-head,
      .surface-head,
      .branch-row,
      .diff-file {
        display: flex;
        align-items: center;
      }

      .demo-sidebar-head {
        justify-content: space-between;
        color: var(--faint);
        font-size: 11px;
        font-weight: 650;
        letter-spacing: 0.08em;
        padding: 0 8px 12px;
        text-transform: uppercase;
      }

      .mini-button {
        display: grid;
        width: 24px;
        height: 24px;
        place-items: center;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: white;
        color: var(--muted);
        font-size: 14px;
      }

      .demo-workspace {
        padding: 9px 0;
      }

      .workspace-row {
        gap: 7px;
        color: var(--text-body);
        font-size: 12px;
        padding: 7px 8px;
      }

      .workspace-row strong {
        overflow: hidden;
        margin-right: auto;
        font-weight: 590;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .chevron {
        width: 9px;
        color: var(--faint);
      }

      .folder-icon {
        width: 12px;
        height: 9px;
        border: 1px solid #9e9489;
        border-radius: 2px;
        position: relative;
      }

      .folder-icon::before {
        position: absolute;
        top: -4px;
        left: 1px;
        width: 5px;
        height: 3px;
        border: 1px solid #9e9489;
        border-bottom: 0;
        border-radius: 2px 2px 0 0;
        content: '';
      }

      .thread-row {
        gap: 9px;
        border-radius: 8px;
        color: #625b54;
        font-size: 11px;
        padding: 8px 8px 8px 31px;
      }

      .thread-row span:nth-child(2) {
        overflow: hidden;
        margin-right: auto;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .thread-row small {
        color: var(--faint);
        font-size: 9px;
      }

      .thread-row.is-active {
        background: #ece4da;
        color: var(--text);
        font-weight: 560;
      }

      .thread-row.needs-attention {
        color: var(--text-body);
      }

      .status-idle {
        background: #c8bfb5;
      }

      .status-attention {
        background: var(--accent);
        box-shadow: 0 0 0 3px rgba(223, 111, 56, 0.1);
      }

      .demo-main {
        position: relative;
        display: flex;
        flex-direction: column;
        padding: 0 28px 24px;
        background: #fdfcfb;
      }

      .demo-main-head {
        justify-content: space-between;
        min-height: 64px;
        border-bottom: 1px solid var(--border);
        font-size: 13px;
      }

      .demo-main-head > div {
        display: flex;
        align-items: center;
        gap: 9px;
      }

      .connected-chip {
        border: 1px solid #b9d4bd;
        border-radius: 999px;
        background: #edf7ee;
        color: #397a45;
        font-size: 10px;
        font-weight: 600;
        padding: 5px 9px;
      }

      .activity-feed {
        display: grid;
        gap: 5px;
        padding: 25px 0 21px;
      }

      .activity-line {
        display: grid;
        grid-template-columns: 26px 1fr auto;
        align-items: center;
        gap: 8px;
        border-radius: 8px;
        color: var(--muted);
        font-size: 11px;
        padding: 7px 9px;
      }

      .activity-line:hover {
        background: var(--bg-deep);
      }

      .activity-line > div {
        display: flex;
        align-items: baseline;
        gap: 7px;
        min-width: 0;
      }

      .activity-line strong {
        color: var(--text-body);
        font-weight: 580;
      }

      .activity-line code,
      .activity-line p {
        overflow: hidden;
        color: var(--faint);
        font-family: var(--mono);
        font-size: 10px;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .activity-icon {
        display: grid;
        width: 24px;
        height: 24px;
        place-items: center;
        border: 1px solid var(--border);
        border-radius: 7px;
        background: white;
        color: var(--muted);
        font-size: 12px;
      }

      .activity-icon-warm {
        background: var(--accent-pale);
        color: var(--accent-strong);
      }

      .activity-ok {
        color: var(--green);
        font-size: 11px;
      }

      .working-dots {
        display: flex;
        gap: 3px;
      }

      .working-dots i {
        width: 3px;
        height: 3px;
        border-radius: 50%;
        background: var(--accent);
        animation: dot-wave 1s ease-in-out infinite;
      }

      .working-dots i:nth-child(2) { animation-delay: 120ms; }
      .working-dots i:nth-child(3) { animation-delay: 240ms; }

      .agent-answer {
        border-top: 1px solid var(--border);
        padding: 23px 6px 20px;
      }

      .answer-kicker {
        display: block;
        margin-bottom: 10px;
        color: var(--accent-strong);
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 650;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .agent-answer p {
        max-width: 610px;
        color: var(--text-body);
        font-size: 13px;
        line-height: 1.65;
      }

      .change-summary {
        display: flex;
        gap: 10px;
        margin-top: 16px;
        color: var(--muted);
        font-family: var(--mono);
        font-size: 10px;
      }

      .change-summary strong,
      .diff-file b {
        color: var(--green);
      }

      .change-summary em,
      .diff-file em {
        color: #c45c50;
        font-style: normal;
      }

      .composer-demo {
        margin-top: auto;
        border: 1px solid var(--border);
        border-radius: 17px;
        background: white;
        box-shadow: 0 8px 24px rgba(54, 36, 22, 0.04);
        color: var(--faint);
        font-size: 12px;
        padding: 17px 17px 10px;
      }

      .composer-controls {
        display: flex;
        align-items: center;
        gap: 15px;
        margin-top: 25px;
        color: var(--muted);
        font-size: 10px;
      }

      .composer-controls b {
        display: grid;
        width: 27px;
        height: 27px;
        place-items: center;
        margin-left: auto;
        border-radius: 50%;
        background: linear-gradient(160deg, #ee9b5b, #df6f38);
        color: white;
      }

      .activity-legend {
        border-left: 1px solid var(--border);
        background: white;
        padding: 27px 22px;
      }

      .legend-label {
        margin-bottom: 27px;
        color: var(--faint);
        font-family: var(--mono);
        font-size: 9px;
        font-weight: 650;
        letter-spacing: 0.11em;
        text-transform: uppercase;
      }

      .activity-legend > div:not(.legend-rule) {
        display: flex;
        align-items: flex-start;
        gap: 11px;
        margin-bottom: 23px;
      }

      .legend-mark {
        display: grid;
        flex: 0 0 auto;
        width: 18px;
        height: 18px;
        place-items: center;
        border-radius: 6px;
        font-size: 9px;
        font-weight: 700;
      }

      .streaming-mark {
        border-radius: 50%;
        background: var(--green);
        box-shadow: 0 0 0 4px rgba(58, 154, 85, 0.1);
        transform: scale(0.38);
      }

      .attention-mark {
        background: var(--accent-pale);
        color: var(--accent-strong);
      }

      .ready-mark {
        background: #edf7ee;
        color: var(--green);
      }

      .activity-legend strong,
      .activity-legend small {
        display: block;
      }

      .activity-legend strong {
        font-size: 11px;
        font-weight: 620;
      }

      .activity-legend small {
        margin-top: 3px;
        color: var(--faint);
        font-size: 9px;
        line-height: 1.35;
      }

      .legend-rule {
        height: 1px;
        margin: 32px 0 20px;
        background: var(--border);
      }

      .legend-note {
        color: var(--muted);
        font-size: 10px;
        line-height: 1.55;
      }

      .under-the-hood {
        background: var(--bg-deep);
      }

      .compact-intro {
        max-width: 840px;
      }

      .compact-intro > p:last-child {
        max-width: 660px;
        margin-top: 27px;
      }

      .protocol-flow {
        display: grid;
        grid-template-columns: 1fr 72px 1fr 72px 1fr 72px 1fr;
        align-items: stretch;
        margin-top: 72px;
      }

      .flow-node {
        position: relative;
        display: flex;
        min-height: 230px;
        flex-direction: column;
        align-items: flex-start;
        justify-content: flex-end;
        overflow: hidden;
        border: 1px solid var(--border-strong);
        border-radius: 19px;
        background: var(--surface);
        box-shadow: var(--shadow-small);
        padding: 22px;
      }

      .flow-node::after {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(207, 106, 58, 0.045) 1px, transparent 1px),
          linear-gradient(90deg, rgba(207, 106, 58, 0.045) 1px, transparent 1px);
        background-size: 24px 24px;
        content: '';
        pointer-events: none;
      }

      .node-number {
        position: absolute;
        top: 17px;
        right: 17px;
        color: var(--faint);
        font-family: var(--mono);
        font-size: 9px;
      }

      .node-icon,
      .code-braces {
        display: grid;
        width: 54px;
        height: 54px;
        place-items: center;
        margin-bottom: 31px;
        border: 1px solid var(--border);
        border-radius: 50%;
        background: white;
        font-family: var(--mono);
        font-size: 13px;
      }

      .flow-logo,
      .vibe-pixel {
        width: 54px;
        height: 54px;
        margin-bottom: 31px;
      }

      .vibe-pixel {
        position: relative;
        display: grid;
        grid-template-columns: repeat(3, 13px);
        grid-template-rows: repeat(3, 13px);
        gap: 3px;
        align-content: center;
        justify-content: center;
      }

      .vibe-pixel i {
        background: var(--accent);
      }

      .vibe-pixel i:nth-child(1) { grid-column: 1; grid-row: 1; }
      .vibe-pixel i:nth-child(2) { grid-column: 3; grid-row: 1; background: var(--gold); }
      .vibe-pixel i:nth-child(3) { grid-column: 2; grid-row: 2; }
      .vibe-pixel i:nth-child(4) { grid-column: 1; grid-row: 3; background: #e2452a; }
      .vibe-pixel i:nth-child(5) { grid-column: 3; grid-row: 3; }

      .flow-node strong {
        position: relative;
        z-index: 1;
        font-size: 14px;
        font-weight: 650;
      }

      .flow-node small {
        position: relative;
        z-index: 1;
        margin-top: 5px;
        color: var(--muted);
        font-size: 11px;
      }

      .flow-arrow {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 6px;
        color: var(--accent);
        font-family: var(--mono);
        font-size: 18px;
      }

      .flow-arrow span {
        color: var(--faint);
        font-size: 8px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .principle-row {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 1px;
        overflow: hidden;
        margin-top: 22px;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: var(--border);
      }

      .principle-row span {
        background: var(--surface);
        color: var(--muted);
        font-size: 12px;
        line-height: 1.45;
        padding: 17px 19px;
      }

      .principle-row b {
        color: var(--text-body);
        font-weight: 620;
      }

      .approval-grid {
        display: grid;
        grid-template-columns: minmax(0, 0.8fr) minmax(420px, 1.1fr);
        align-items: center;
        gap: clamp(70px, 10vw, 140px);
      }

      .approval-copy > p {
        margin-top: 27px;
      }

      .approval-copy ul {
        display: grid;
        gap: 0;
        margin-top: 36px;
        list-style: none;
      }

      .approval-copy li {
        display: flex;
        align-items: center;
        gap: 15px;
        border-top: 1px solid var(--border);
        color: var(--text-body);
        font-size: 14px;
        padding: 15px 0;
      }

      .approval-copy li:last-child {
        border-bottom: 1px solid var(--border);
      }

      .approval-copy li span {
        color: var(--accent-strong);
        font-family: var(--mono);
        font-size: 10px;
      }

      .permission-scene {
        position: relative;
        min-height: 520px;
      }

      .permission-scene::before {
        position: absolute;
        inset: 25px 10px 60px;
        border: 1px solid var(--border);
        border-radius: 24px;
        background:
          linear-gradient(rgba(207, 106, 58, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(207, 106, 58, 0.05) 1px, transparent 1px),
          var(--bg-deep);
        background-size: 32px 32px;
        content: '';
      }

      .permission-backplate {
        position: absolute;
        top: 70px;
        right: 0;
        display: grid;
        grid-template-columns: auto auto;
        gap: 8px 18px;
        width: 255px;
        border: 1px solid var(--border);
        border-radius: 14px;
        background: white;
        box-shadow: var(--shadow-small);
        color: var(--faint);
        font-family: var(--mono);
        font-size: 8px;
        letter-spacing: 0.08em;
        padding: 19px;
      }

      .permission-backplate b {
        color: var(--text-body);
        font-size: 9px;
        letter-spacing: 0;
        text-align: right;
      }

      .permission-card {
        position: absolute;
        top: 155px;
        left: 0;
        z-index: 2;
        width: min(100% - 35px, 480px);
        overflow: hidden;
        border: 1px solid #dfc4b3;
        border-radius: 19px;
        background: white;
        box-shadow: 0 28px 60px -30px rgba(91, 45, 20, 0.45);
      }

      .permission-head {
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: 12px;
        border-bottom: 1px solid #eeded2;
        background: var(--accent-pale);
        padding: 16px 18px;
      }

      .shield-icon {
        display: grid;
        width: 34px;
        height: 34px;
        place-items: center;
        border-radius: 10px;
        background: white;
        color: var(--accent-strong);
        font-size: 19px;
      }

      .permission-head strong,
      .permission-head small {
        display: block;
      }

      .permission-head strong {
        font-size: 13px;
        font-weight: 650;
      }

      .permission-head small {
        margin-top: 2px;
        color: var(--muted);
        font-size: 10px;
      }

      .permission-time {
        color: var(--faint);
        font-size: 9px;
      }

      .permission-body {
        display: grid;
        gap: 11px;
        padding: 20px 19px 17px;
      }

      .permission-body p {
        color: var(--text-body);
        font-size: 12px;
      }

      .permission-body code {
        overflow: hidden;
        border: 1px solid var(--border);
        border-radius: 8px;
        background: var(--bg-deep);
        color: var(--text-body);
        font-family: var(--mono);
        font-size: 10px;
        padding: 11px 12px;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .path-label {
        color: var(--faint);
        font-family: var(--mono);
        font-size: 9px;
      }

      .permission-actions {
        display: flex;
        justify-content: flex-end;
        gap: 8px;
        border-top: 1px solid var(--border);
        padding: 12px 15px;
      }

      .permission-actions span {
        border-radius: 8px;
        font-size: 10px;
        font-weight: 620;
        padding: 8px 11px;
      }

      .permission-reject {
        border: 1px solid var(--border);
        color: var(--muted);
      }

      .permission-allow {
        background: var(--text);
        color: white;
      }

      .mode-switcher {
        position: absolute;
        right: 23px;
        bottom: 24px;
        z-index: 3;
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        max-width: 405px;
        border: 1px solid var(--border-strong);
        border-radius: 12px;
        background: white;
        box-shadow: var(--shadow-small);
        padding: 5px;
      }

      .mode-switcher span {
        border-radius: 8px;
        color: var(--muted);
        font-size: 9px;
        padding: 8px 9px;
      }

      .mode-switcher .is-selected {
        background: var(--accent-soft);
        color: var(--accent-strong);
        font-weight: 650;
      }

      .side-work {
        background: var(--bg-deep);
      }

      .side-work-intro {
        align-items: center;
      }

      .side-work-stage {
        position: relative;
        min-height: 650px;
        margin-top: 72px;
        border: 1px solid var(--border-strong);
        border-radius: 24px;
        background:
          radial-gradient(circle at 50% 30%, rgba(246, 196, 69, 0.15), transparent 36%),
          linear-gradient(rgba(207, 106, 58, 0.05) 1px, transparent 1px),
          linear-gradient(90deg, rgba(207, 106, 58, 0.05) 1px, transparent 1px),
          #f7f4ef;
        background-size: auto, 34px 34px, 34px 34px, auto;
      }

      .surface-files,
      .surface-git,
      .surface-terminal {
        position: absolute;
        overflow: hidden;
        border: 1px solid var(--border-strong);
        border-radius: 17px;
        background: white;
        box-shadow: 0 24px 50px -28px rgba(54, 36, 22, 0.45);
      }

      .surface-files {
        top: 70px;
        left: 6%;
        z-index: 1;
        width: 34%;
        min-height: 455px;
        transform: rotate(-2.2deg);
      }

      .surface-git {
        top: 36px;
        left: 35%;
        z-index: 3;
        width: 38%;
        min-height: 500px;
      }

      .surface-terminal {
        right: 5%;
        bottom: 61px;
        z-index: 4;
        width: 36%;
        transform: rotate(1.8deg);
        background: var(--terminal);
        color: #d8d2ca;
      }

      .surface-head {
        min-height: 51px;
        gap: 8px;
        border-bottom: 1px solid var(--border);
        padding: 0 16px;
        font-size: 12px;
      }

      .surface-head strong {
        font-weight: 650;
      }

      .surface-head span {
        margin-right: auto;
        color: var(--faint);
        font-size: 9px;
      }

      .surface-head i {
        color: var(--muted);
        font-style: normal;
      }

      .file-search {
        margin: 12px;
        border: 1px solid var(--border);
        border-radius: 7px;
        color: var(--faint);
        font-size: 10px;
        padding: 9px 10px;
      }

      .file-tree {
        display: grid;
        gap: 2px;
        padding: 0 12px 16px;
      }

      .file-tree span {
        border-radius: 6px;
        color: var(--muted);
        font-size: 10px;
        padding: 6px 8px;
      }

      .file-tree b {
        color: var(--text-body);
        font-weight: 570;
      }

      .file-tree .depth-one { padding-left: 24px; }
      .file-tree .depth-two { padding-left: 41px; }
      .file-tree .is-file { font-family: var(--mono); font-size: 9px; }
      .file-tree .is-active { background: var(--accent-pale); color: var(--accent-strong); }

      .branch-row {
        gap: 9px;
        border-bottom: 1px solid var(--border);
        color: var(--muted);
        font-size: 10px;
        padding: 14px 16px;
      }

      .branch-row b {
        margin-right: auto;
        color: var(--text-body);
        font-family: var(--mono);
        font-size: 9px;
      }

      .branch-row small {
        color: var(--faint);
      }

      .diff-file {
        gap: 9px;
        border-bottom: 1px solid #f2ece6;
        color: var(--muted);
        font-size: 9px;
        padding: 12px 16px;
      }

      .diff-file > span {
        color: var(--accent-strong);
        font-family: var(--mono);
      }

      .diff-file code {
        overflow: hidden;
        margin-right: auto;
        color: var(--text-body);
        font-family: var(--mono);
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .commit-box {
        margin: 18px 16px 9px;
        border: 1px solid var(--border);
        border-radius: 8px;
        color: var(--text-body);
        font-size: 10px;
        padding: 11px;
      }

      .commit-button {
        display: flex;
        justify-content: center;
        gap: 16px;
        margin: 0 16px 17px;
        border-radius: 8px;
        background: var(--text);
        color: white;
        font-size: 10px;
        font-weight: 620;
        padding: 10px;
      }

      .commit-button span {
        color: #aaa39c;
        font-family: var(--mono);
      }

      .terminal-head {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        min-height: 45px;
        border-bottom: 1px solid rgba(255, 255, 255, 0.08);
        padding: 0 13px;
      }

      .terminal-head > span {
        display: flex;
        gap: 5px;
      }

      .terminal-head i {
        width: 7px;
        height: 7px;
        border-radius: 50%;
        background: #ec6a5e;
      }

      .terminal-head i:nth-child(2) { background: #f4bf4f; }
      .terminal-head i:nth-child(3) { background: #61c554; }

      .terminal-head strong {
        font-size: 9px;
        font-weight: 550;
      }

      .terminal-head small {
        justify-self: end;
        color: #7b756f;
        font-family: var(--mono);
        font-size: 8px;
      }

      .terminal-body,
      .open-terminal-body {
        font-family: var(--mono);
        font-size: 10px;
        line-height: 1.8;
        padding: 21px;
      }

      .terminal-body b { color: #d8d2ca; font-weight: 550; }
      .terminal-body span { color: #d99764; }
      .terminal-body i,
      .open-terminal-body i { color: #7fb56b; font-style: normal; }
      .terminal-body .terminal-muted { color: #807a74; }

      .terminal-cursor {
        display: inline-block;
        width: 6px;
        height: 12px;
        background: currentColor;
        vertical-align: -2px;
        animation: cursor-blink 1.1s step-end infinite;
      }

      .surface-tabs {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        margin-top: 23px;
        border-block: 1px solid var(--border);
      }

      .surface-tabs span {
        display: flex;
        gap: 10px;
        border-right: 1px solid var(--border);
        color: var(--muted);
        font-size: 12px;
        padding: 17px 18px;
      }

      .surface-tabs span:last-child { border-right: 0; }
      .surface-tabs b { color: var(--accent-strong); font-family: var(--mono); font-size: 10px; }

      .open-source {
        border-top: 0;
        background: var(--bg-deep);
        padding-top: 0;
      }

      .open-panel {
        position: relative;
        display: grid;
        grid-template-columns: minmax(0, 0.8fr) minmax(430px, 1fr);
        align-items: center;
        gap: 90px;
        min-height: 580px;
        overflow: hidden;
        border: 1px solid #ca693e;
        border-radius: 28px;
        background: linear-gradient(135deg, #ef945d 0%, #e47a42 52%, #d65c34 100%);
        box-shadow: 0 30px 70px -38px rgba(154, 67, 28, 0.6);
        padding: 70px;
      }

      .open-grid {
        z-index: 0;
        background-image:
          linear-gradient(rgba(91, 42, 20, 0.11) 1px, transparent 1px),
          linear-gradient(90deg, rgba(91, 42, 20, 0.11) 1px, transparent 1px);
        background-size: 35px 35px;
        mask-image: linear-gradient(90deg, black, transparent 75%);
        -webkit-mask-image: linear-gradient(90deg, black, transparent 75%);
      }

      .open-copy,
      .open-terminal {
        position: relative;
        z-index: 1;
      }

      .open-copy .eyebrow {
        color: #5b2a18;
      }

      .open-copy h2 {
        color: #241a12;
      }

      .open-copy > p {
        margin-top: 25px;
        color: rgba(46, 28, 18, 0.76);
      }

      .open-actions {
        display: flex;
        align-items: center;
        gap: 16px;
        margin-top: 29px;
      }

      .button-dark {
        background: #241a12;
        color: white;
        box-shadow: 0 16px 30px -14px rgba(62, 26, 11, 0.52);
      }

      .open-actions > span {
        color: rgba(46, 28, 18, 0.72);
        font-family: var(--mono);
        font-size: 10px;
        text-transform: uppercase;
      }

      .open-terminal {
        overflow: hidden;
        border: 1px solid rgba(49, 29, 18, 0.25);
        border-radius: 17px;
        background: #fffaf5;
        box-shadow: 0 28px 65px -30px rgba(74, 30, 13, 0.6);
        transform: rotate(1.5deg);
      }

      .open-terminal-head {
        position: relative;
        align-items: center;
        min-height: 47px;
        border-bottom: 1px solid #ead7c8;
        background: #f4e9df;
        padding: 0 15px;
      }

      .open-terminal-head small {
        position: absolute;
        left: 50%;
        color: #7b6f65;
        font-family: var(--mono);
        font-size: 9px;
        transform: translateX(-50%);
      }

      .open-terminal-body {
        min-height: 300px;
        color: #3e352f;
        font-size: 11px;
        line-height: 2.05;
        padding: 29px;
      }

      .open-terminal-body i { color: #b9512d; }
      .open-terminal-body .terminal-comment { color: #9f8e81; }
      .open-terminal-body .terminal-success { color: #397a45; }

      .final-cta {
        position: relative;
        overflow: hidden;
        border-top: 1px solid var(--border);
        padding: 145px 0 135px;
        isolation: isolate;
      }

      .final-grid {
        mask-image: radial-gradient(circle at center, black, transparent 70%);
        -webkit-mask-image: radial-gradient(circle at center, black, transparent 70%);
      }

      .final-cta-inner {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
      }

      .final-cta h2 {
        font-size: clamp(62px, 8.2vw, 102px);
      }

      .final-cta-inner > p:not(.eyebrow):not(.final-note) {
        max-width: 590px;
        margin-top: 24px;
        font-size: 19px;
      }

      footer {
        border-top: 1px solid var(--border);
        background: var(--bg-deep);
        color: var(--muted);
        padding: 34px 0 24px;
      }

      .footer-inner {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
      }

      .footer-brand {
        font-size: 14px;
      }

      .footer-brand .brand-mark {
        width: 24px;
        height: 24px;
      }

      .footer-inner > p {
        font-size: 11px;
      }

      .footer-links {
        display: flex;
        justify-self: end;
        gap: 22px;
      }

      .footer-links a {
        font-size: 12px;
      }

      .disclaimer {
        margin-top: 18px;
        color: var(--faint);
        font-size: 9px;
        text-align: center;
      }

      @keyframes enter {
        to { opacity: 1; transform: none; }
      }

      @keyframes float-one {
        0%, 100% { transform: translateY(0) rotate(-4deg); }
        50% { transform: translateY(-7px) rotate(-3deg); }
      }

      @keyframes float-two {
        0%, 100% { transform: translateY(0) rotate(3deg); }
        50% { transform: translateY(7px) rotate(2deg); }
      }

      @keyframes status-pulse {
        0%, 100% { box-shadow: 0 0 0 3px rgba(58, 154, 85, 0.1); }
        50% { box-shadow: 0 0 0 6px rgba(58, 154, 85, 0.02); }
      }

      @keyframes dot-wave {
        0%, 100% { opacity: 0.25; transform: translateY(0); }
        50% { opacity: 1; transform: translateY(-2px); }
      }

      @keyframes cursor-blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
      }

      @media (max-width: 1100px) {
        .stage-label-workspace { left: -20px; }
        .stage-label-thread { right: -20px; }
        .workspace-demo { grid-template-columns: 220px minmax(0, 1fr); }
        .activity-legend { display: none; }
        .protocol-flow { grid-template-columns: 1fr 45px 1fr; gap: 0; }
        .protocol-flow .flow-node:nth-of-type(3),
        .protocol-flow .flow-node:nth-of-type(4) { margin-top: 45px; }
        .protocol-flow .flow-arrow:nth-of-type(2) { display: none; }
        .open-panel { gap: 55px; padding: 55px; }
      }

      @media (max-width: 820px) {
        .container { width: min(100% - 32px, 1180px); }
        .nav-shell { grid-template-columns: 1fr auto; }
        nav { display: none; }
        .hero { padding-top: 80px; }
        h1 { font-size: clamp(54px, 13vw, 82px); }
        .app-stage { margin-top: 62px; }
        .stage-label { display: none; }
        .stage-caption { padding-bottom: 55px; }
        .section { padding: 90px 0; }
        .split-intro,
        .approval-grid,
        .open-panel { grid-template-columns: 1fr; }
        .split-intro { gap: 28px; }
        .split-intro > p { max-width: 620px; }
        .workspace-demo { grid-template-columns: 190px minmax(0, 1fr); min-height: 560px; }
        .demo-main { padding-inline: 20px; }
        .protocol-flow { grid-template-columns: 1fr 44px 1fr; }
        .principle-row { grid-template-columns: 1fr; }
        .approval-grid { gap: 45px; }
        .permission-scene { width: min(100%, 610px); margin-inline: auto; }
        .side-work-stage { min-height: 590px; }
        .surface-files { left: 3%; width: 43%; }
        .surface-git { left: 29%; width: 48%; }
        .surface-terminal { right: 2%; width: 47%; }
        .open-panel { gap: 50px; padding: 55px; }
        .open-terminal { width: min(100%, 560px); }
        .footer-inner { grid-template-columns: 1fr auto; gap: 24px; }
        .footer-inner > p { grid-column: 1 / -1; grid-row: 2; text-align: center; }
      }

      @media (max-width: 640px) {
        .header-download { padding: 9px 11px; }
        .header-download svg { display: none; }
        .hero { padding-top: 70px; }
        .hero-eyebrow { font-size: 10px; }
        h1 { font-size: clamp(48px, 14vw, 68px); line-height: 0.95; }
        .lede { font-size: 17px; }
        .hero-actions { width: 100%; }
        .hero-actions .button { width: 100%; }
