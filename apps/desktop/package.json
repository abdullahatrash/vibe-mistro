{
  "name": "vibe-mistro",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "description": "Desktop orchestrator for Mistral Vibe coding agents, driven over the Agent Client Protocol (ACP).",
  "main": "./out/main/index.js",
  "author": "Abdullah Atrash",
  "license": "MIT",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "start": "electron-vite preview",
    "typecheck": "tsc --noEmit -p tsconfig.node.json && tsc --noEmit -p tsconfig.web.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:update": "playwright test --update-snapshots",
    "lint": "eslint .",
    "dist": "electron-vite build && electron-builder --mac --arm64 --publish never",
    "dist:unsigned": "CSC_IDENTITY_AUTO_DISCOVERY=false bun run dist",
    "release": "electron-vite build && electron-builder --mac --arm64 --publish always",
    "postinstall": "node scripts/fix-node-pty-perms.mjs && node scripts/patch-dev-electron.mjs"
  },
  "dependencies": {
    "chokidar": "^5.0.0",
    "electron-updater": "^6.6.2",
    "node-pty": "^1.1.0"
  },
  "devDependencies": {
    "@base-ui/react": "^1.4.1",
    "@eslint/js": "10.0.1",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@pierre/diffs": "^1.2.12",
    "@pierre/trees": "1.0.0-beta.5",
    "@playwright/test": "^1.61.1",
    "@streamdown/code": "1.1.1",
    "@tailwindcss/vite": "^4",
    "@types/mdast": "^4.0.4",
    "@types/node": "^22.10.0",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron": "^33.2.1",
    "electron-builder": "26.8.1",
    "electron-vite": "^2.3.0",
    "eslint": "10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "globals": "^17.7.0",
    "lucide-react": "^0.564",
    "mdast-util-find-and-replace": "^3.0.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "shiki": "3.23.0",
    "streamdown": "2.5.0",
    "tailwind-merge": "^3",
    "tailwindcss": "^4",
    "typescript": "^5.7.2",
    "typescript-eslint": "8.62.0",
    "unified": "^11.0.5",
    "use-stick-to-bottom": "^1.1.6",
    "vite": "^5.4.11",
    "vitest": "^4.1.9"
  }
}
