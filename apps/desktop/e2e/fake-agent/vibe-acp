#!/usr/bin/env node
/**
 * A scripted fake `vibe-acp` for the e2e visual smoke suite (slice 2): speaks
 * just enough ACP — newline-delimited JSON-RPC 2.0 over stdio — for the app to
 * connect, open a session, and stream one fully deterministic turn. Every shape
 * below is copied from the verbatim captures in `docs/acp-capture.md` (§1, §2,
 * §3, §4, §8), so if the app's parser tightens against the real agent, this
 * fake breaks the same way.
 *
 * Deliberately dumb by default: fixed session ids, fixed reply text, fixed usage
 * numbers, no auth dance (always signed in). Opt-in env seams add a held turn,
 * one Permission request, and an append-only protocol log for lifecycle E2E tests;
 * existing visual scenarios remain byte-for-byte deterministic without those vars.
 * Anything unexpected gets a -32601 so a new app-side call FAILS LOUDLY in the
 * suite instead of hanging a request.
 */

const { appendFileSync } = process.getBuiltinModule('node:fs')

const out = (msg) => process.stdout.write(JSON.stringify(msg) + '\n')
const reply = (id, result) => out({ jsonrpc: '2.0', id, result })
const fail = (id, code, message) => out({ jsonrpc: '2.0', id, error: { code, message, data: null } })
const notify = (method, params) => out({ jsonrpc: '2.0', method, params })
const sleep = (ms) => new Promise((resolve) => setTimeout(resolve, ms))

const LOG_PATH = process.env.VIBE_MISTRO_FAKE_LOG_PATH
const TURN_HOLD_MS = Math.max(
  0,
  Number.parseInt(process.env.VIBE_MISTRO_FAKE_TURN_HOLD_MS ?? '0', 10) || 0,
)
const PERMISSION_TRIGGER = process.env.VIBE_MISTRO_FAKE_PERMISSION_TRIGGER ?? ''
const DISTINCT_TITLES = process.env.VIBE_MISTRO_FAKE_DISTINCT_TITLES === '1'

function log(event, fields = {}) {
  if (!LOG_PATH) return
  appendFileSync(LOG_PATH, `${JSON.stringify({ at: Date.now(), event, ...fields })}\n`)
}

let sessionSeq = 0
let permissionSeq = 0
const pendingPermissionReplies = new Map()

/** acp-capture §2 — the modes/models/configOptions bundle `session/new` reports. */
const MODES = {
  currentModeId: 'default',
  availableModes: [
    { id: 'default', name: 'Default', description: 'Requires approval for tool executions' },
    { id: 'plan', name: 'Plan', description: 'Read-only agent for exploration and planning' },
    { id: 'accept-edits', name: 'Accept Edits', description: 'Auto-approves file edits only' },
    { id: 'auto-approve', name: 'Auto Approve', description: 'Auto-approves all tool executions' },
    { id: 'chat', name: 'Chat', description: 'Read-only conversational mode' },
  ],
}
const MODELS = {
  currentModelId: 'mistral-medium-3.5',
  availableModels: [
    { modelId: 'mistral-medium-3.5', name: 'mistral-medium-3.5' },
    { modelId: 'devstral-small', name: 'devstral-small' },
    { modelId: 'local', name: 'local' },
  ],
}
const CONFIG_OPTIONS = [
  {
    id: 'thinking',
    currentValue: 'high',
    options: [
      { value: 'off' },
      { value: 'low' },
      { value: 'medium' },
      { value: 'high' },
      { value: 'max' },
    ],
  },
]

async function dispatch(msg) {
  // A reply to an opt-in agent→client Permission request has no `method`. Consume
  // it before normal request dispatch so it cannot fall through to -32601.
  if (msg.method === undefined && msg.id !== undefined) {
    const resolvePermission = pendingPermissionReplies.get(String(msg.id))
    if (resolvePermission) {
      pendingPermissionReplies.delete(String(msg.id))
      log('permission:resolved', { requestId: msg.id, result: msg.result ?? null })
      resolvePermission(msg.result)
      return
    }
  }

  log('request', {
    method: msg.method ?? null,
    sessionId: msg.params?.sessionId ?? null,
  })
  switch (msg.method) {
    case 'initialize':
      // acp-capture §1.
      reply(msg.id, {
        agentCapabilities: {
          loadSession: true,
          promptCapabilities: { audio: false, embeddedContext: true, image: true },
          sessionCapabilities: { close: {}, fork: {}, list: {} },
        },
        agentInfo: { name: 'fake-vibe-acp', title: 'Fake Vibe (e2e)', version: '0.0.0' },
        authMethods: [
          {
            id: 'browser-auth',
            name: 'Sign in through Mistral AI Studio',
            description: 'Fake sign-in (never needed — _auth/status is always signed in).',
          },
        ],
        protocolVersion: 1,
      })
      return
    case '_auth/status':
      // acp-capture §8 — always signed in, so the suite never sees the sign-in panel.
      reply(msg.id, { authenticated: true, authState: 'os_keyring', signOutAvailable: true })
      return
    case 'session/new':
      // acp-capture §2. Deterministic ids so replays/screens can't drift.
      sessionSeq += 1
      log('session:new', { sessionId: `fake-session-${sessionSeq}` })
      reply(msg.id, {
        sessionId: `fake-session-${sessionSeq}`,
        modes: MODES,
        models: MODELS,
        configOptions: CONFIG_OPTIONS,
      })
      return
    case 'session/load': {
      // Deterministic restart-resume seam. Real Vibe returns the session/new-shaped
      // controls bundle without a sessionId (the caller already supplied the cursor).
      // No replay notifications are needed here: the app's own transcript is the
      // restoration source under test.
      const sessionId = msg.params?.sessionId
      log('session:load', { sessionId })
      reply(msg.id, {
        modes: MODES,
        models: MODELS,
        configOptions: CONFIG_OPTIONS,
      })
      return
    }
    case 'session/prompt':
      await streamTurn(msg)
      return
    case 'session/cancel':
    case 'session/close':
    case 'session/set_mode':
    case 'session/set_model':
    case 'session/set_config_option':
      reply(msg.id, {})
      return
    default:
      // A request we don't script: fail loudly (a silent drop would hang the
      // app-side request and stall the suite until its timeout).
      if (msg.id !== undefined) fail(msg.id, -32601, `fake-vibe-acp: method not found: ${msg.method}`)
  }
}

/** One deterministic turn (acp-capture §3/§4): title, three message chunks, usage, end_turn. */
async function streamTurn(msg) {
  const sessionId = msg.params?.sessionId
  const promptText = Array.isArray(msg.params?.prompt)
    ? msg.params.prompt
        .filter((block) => block?.type === 'text' && typeof block.text === 'string')
        .map((block) => block.text)
        .join('\n')
    : ''
  log('prompt:start', { sessionId, promptText })
  const update = (u) => notify('session/update', { sessionId, update: u })
  update({
    sessionUpdate: 'session_info_update',
    title: DISTINCT_TITLES ? `Fake ${sessionId}` : 'Fake deterministic thread',
  })

  if (PERMISSION_TRIGGER && promptText.includes(PERMISSION_TRIGGER)) {
    await requestPermission(sessionId)
  }
  if (TURN_HOLD_MS > 0) await sleep(TURN_HOLD_MS)

  const chunks = [
    'Hello from the **fake agent**. ',
    'This reply is fully deterministic, ',
    'so the visual smoke suite can pin it to the pixel.',
  ]
  for (const text of chunks) {
    update({ sessionUpdate: 'agent_message_chunk', content: { type: 'text', text }, messageId: 'fake-msg-1' })
    await sleep(30)
  }
  update({ sessionUpdate: 'usage_update', used: 1234, size: 200000, cost: { amount: 0.0042, currency: 'USD' } })
  log('prompt:end', { sessionId })
  reply(msg.id, {
    stopReason: 'end_turn',
    usage: { inputTokens: 1000, outputTokens: 34, totalTokens: 1034 },
    userMessageId: 'fake-user-1',
  })
}

/** Opt-in captured-shape Permission request; resolves only after the app answers it. */
async function requestPermission(sessionId) {
  permissionSeq += 1
  const requestId = `fake-permission-${permissionSeq}`
  log('permission:requested', { requestId, sessionId })
  out({
    jsonrpc: '2.0',
    id: requestId,
    method: 'session/request_permission',
    params: {
      sessionId,
      toolCall: { toolCallId: `fake-tool-${permissionSeq}` },
      options: [
        { kind: 'allow_once', name: 'Allow once', optionId: 'allow_once' },
        { kind: 'reject_once', name: 'Deny', optionId: 'reject_once' },
      ],
    },
  })
  await new Promise((resolve) => pendingPermissionReplies.set(requestId, resolve))
}

let buffer = ''
process.stdin.setEncoding('utf8')
process.stdin.on('data', (data) => {
  buffer += data
  let newline
  while ((newline = buffer.indexOf('\n')) !== -1) {
    const line = buffer.slice(0, newline).trim()
    buffer = buffer.slice(newline + 1)
    if (!line) continue
    try {
      void dispatch(JSON.parse(line))
    } catch {
      // Unparseable line: ignore (the real agent tolerates garbage on stdin too).
    }
  }
})
process.stdin.on('end', () => process.exit(0))
